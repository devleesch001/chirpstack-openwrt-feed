#!/bin/sh

# AW2013 LED controller script
# === CONFIGURATION (Overridable via Environment Variables) ===
I2C_PORT="${I2C_PORT:-0}"
I2C_ADDR="${I2C_ADDR:-0x45}"
I2C_DEVICE="/dev/i2c-$I2C_PORT"
VERBOSE=0

# Usage function
usage() {
    echo "\
AW2013 Command Controller
Control the RGB LED via I2C for the AW2013 chip.

Usage: $0 [OPTIONS] <Command> <Params>
    Options:
      -h, --help      Show this help message and exit
      -v, --verbose   Print detailed execution logs and i2cset commands

    Commands:
      reset           Reset AW2013 registers to default
      init            Initialize the controller (Fade in/out, PWM mode)
      color <color>   Set a predefined color (red, green, blue, white, off...)
      rgb <R> <G> <B> Set a custom RGB color using hex values (e.g., 0xFF 0x00 0x88)
      breathe         Start breathing mode (Default: LTC0=0x34, LTC1=0x30)
      breathe <V>     Start breathing mode with LTC0=V and LTC1=V (e.g., breathe 0x30)
      breathe <V> <W> Start breathing mode with LTC0=V and LTC1=W (e.g., breathe 0x34 0x30)

    Examples:
      $0 reset
      $0 color purple
      $0 --verbose rgb 0x00 0x33 0x99
      $0 breathe 0x11

    Chaining Examples:
      $0 color cyan breathe 0x34 0x30
      $0 reset rgb 0xFF 0x00 0x00 breathe
"
    exit 1
}

# Verbose print function
vprint() {
    if [ "$VERBOSE" -eq 1 ]; then
        echo "$@"
    fi
}

# Wrapper for i2cset
i2c_write() {
    REG="$1"
    VAL="$2"

    # Utilisation de vprint pour afficher la commande exacte
    vprint "i2cset -y $I2C_PORT $I2C_ADDR $REG $VAL"

    i2cset -y "$I2C_PORT" "$I2C_ADDR" "$REG" "$VAL"
}

check_device() {
    # Checking i2c port available
    if [ ! -c "$I2C_DEVICE" ]; then
        echo "Error: $I2C_DEVICE port not found." >&2
        exit 1
    fi

    # Read the IADR register (0x77) which defaults to the I2C address
    REG_VALUE=$(i2cget -y "$I2C_PORT" "$I2C_ADDR" 0x77 2>/dev/null)

    # Check if the returned value matches the expected default I2C address
    if [ "$REG_VALUE" != "$I2C_ADDR" ]; then
        echo "Error: The device $I2C_DEVICE does not seem to return its address (Read value: ${REG_VALUE:-'none'})." >&2
        echo "It might not be the correct controller (AW2013 expected)." >&2
        exit 1
    fi
}

reset() {
    vprint "# reset"
    check_device || return
    # RSTR (0x00) set to 0x55 for soft reset
    i2c_write 0x00 0x55
}

# Setup LED
init_device() {
    vprint "# init_device"
    check_device || return

    # Enable LED GCR
    i2c_write 0x01 0x01

    # PWM Control Mode LCFG
    # Fade Out, Fade In, PWM, 15mA
    # Bit 7   | Bit 6 (FO) | Bit 5 (FI) | Bit 4 (MD) | Bit 3    | Bit 2    | Bits 1 et 0 (IMAX)
    # 0 (Fixe)| Fade Out   | Fade In    | Mode       | 0 (Fixe) | 0 (Fixe) | Power
    # 0       | 1          | 1          | 0          | 0        | 0        | 11
    # 0x63 = 01100011 binary
    i2c_write 0x31 0x63
    i2c_write 0x32 0x63
    i2c_write 0x33 0x63

    # 1. Enable all 3 LED channels in the LCTR register (0x30)
    # 0x07 (binary 00000111) turns on LE0, LE1, and LE2
    i2c_write 0x30 0x07
}

set_color() {
    vprint "# set_color $1"
    COLOR="$1"

    # Default value for all RGB channels
    VAL_R="0x00"
    VAL_G="0x00"
    VAL_B="0x00"

    # Map colors directly to PWM values instead of LCTR
    case "$COLOR" in
    r | red) VAL_R="0xFF" ;;
    g | green) VAL_G="0xFF" ;;
    b | blue) VAL_B="0xFF" ;;
    y | yellow)
        VAL_R="0xFF"
        VAL_G="0xFF"
        ;;
    p | purple)
        VAL_R="0xFF"
        VAL_B="0xFF"
        ;;
    c | cyan)
        VAL_G="0xFF"
        VAL_B="0xFF"
        ;;
    w | white)
        VAL_R="0xFF"
        VAL_G="0xFF"
        VAL_B="0xFF"
        ;;
    o | off | false) ;; # All stay at 0x00
    *)
        echo "Error: Unknown color '$COLOR'" >&2
        echo "Available: red, green, blue, yellow, purple, cyan, white, off" >&2
        exit 1
        ;;
    esac

    vprint "# Setting preset color: $COLOR"

    # Apply the PWM values to set the color
    i2c_write 0x34 "$VAL_R"
    i2c_write 0x35 "$VAL_G"
    i2c_write 0x36 "$VAL_B"
}

set_rgb() {
    # Check if exactly 3 arguments are passed
    if [ "$#" -ne 3 ]; then
        echo "Error: rgb requires exactly 3 parameters (Red, Green, Blue)." >&2
        echo "Usage: rgb <R> <G> <B>" >&2
        echo "Example: rgb 0x00 0x33 0x99" >&2
        exit 1
    fi
    vprint "# set_rgb $1 $2 $3"

    VAL_R="$1"
    VAL_G="$2"
    VAL_B="$3"

    vprint "# Applying RGB color: R=$VAL_R, G=$VAL_G, B=$VAL_B"

    # 2. Set the intensity for each channel using the PWM registers
    i2c_write 0x34 "$VAL_R" # PWM0 (Red)
    i2c_write 0x35 "$VAL_G" # PWM1 (Green)
    i2c_write 0x36 "$VAL_B" # PWM2 (Blue)
}

set_breathing() {
    # Default value for register
    VAL_LTC0="${1:-0x34}"
    VAL_LTC1="${2:-0x30}"

    # If only one argument is received, apply it to both registers
    if [ "$#" -eq 1 ]; then
        VAL_LTC1="$1"
    fi
    vprint "# set_breathing"
    vprint "# Enabling Breathing Mode (Synchronized One-Shot)..."
    vprint "# Timings applied : LTC0=$VAL_LTC0, LTC1=$VAL_LTC1"

    # Step a: Set LCTR to 00h (Disable LEDs to sync them)
    i2c_write 0x30 0x00

    # Step b: Set LCFGx MD to "0" (Temporary PWM mode for config)
    i2c_write 0x31 0x03
    i2c_write 0x32 0x03
    i2c_write 0x33 0x03

    # Step c: Configure timing T0-T4
    # LEDxT0 (T1, T2)
    i2c_write 0x37 "$VAL_LTC0"
    i2c_write 0x3a "$VAL_LTC0"
    i2c_write 0x3d "$VAL_LTC0"

    # LEDxT1 (T3, T4)
    i2c_write 0x38 "$VAL_LTC1"
    i2c_write 0x3B "$VAL_LTC1"
    i2c_write 0x3E "$VAL_LTC1"

    # LEDxT2 (T0, Repeat): T0=0s, Repeat=Continuous -> Value: 0x00
    i2c_write 0x39 0x00
    i2c_write 0x3C 0x00
    i2c_write 0x3F 0x00

    # NOTE: We purposely DO NOT set PWM (0x34, 0x35, 0x36) here
    # so it keeps the previous color set by the 'rgb' or 'color' command!

    # Step d: Set LCFGx MD to "1" (Enable One-Shot breathing mode)
    # Bit 4 (MD)=1, Bits 1-0 (IMAX)=11 -> 0001 0011 binary = 0x13 hex
    i2c_write 0x31 0x13
    i2c_write 0x32 0x13
    i2c_write 0x33 0x13

    # Step e: Set LCTR to 07h (Enable all 3 LEDs at the exact same time)
    i2c_write 0x30 0x07
}

# If no arguments provided, show help
if [ "$#" -eq 0 ]; then
    usage
fi

# Parse command line arguments
while [ "$#" -gt 0 ]; do
    case "$1" in
    -h | --help | help)
        usage
        ;;
    -v | --verbose)
        VERBOSE=1
        shift
        ;;
    reset)
        vprint "# Resetting device..."
        reset
        shift
        ;;
    init)
        vprint "# Initialize device"
        init_device
        shift
        ;;
    colour | color)
        if [ "$#" -lt 2 ]; then
            echo "Error: You must provide a color (e.g., red, blue, off)." >&2
            exit 1
        fi
        init_device
        set_color "$2"
        shift 2
        ;;
    rgb)
        if [ "$#" -lt 4 ]; then
            echo "Error: 'rgb' command requires 3 values." >&2
            echo "Example: $0 rgb 0x00 0x33 0x99" >&2
            exit 1
        fi
        init_device
        set_rgb "$2" "$3" "$4"
        shift 4
        ;;
    breathe)
        check_device || exit 1
        shift # Consume the 'breathe' command

        ARG1=""
        ARG2=""

        # Check if the next argument starts with 0x or a digit (0-9)
        case "$1" in
            0x*|[0-9]*) ARG1="$1"; shift ;;
        esac

        # Repeat the same check for the second argument
        case "$1" in
            0x*|[0-9]*) ARG2="$1"; shift ;;
        esac

        # Call the function based on the number of arguments retrieved
        if [ -n "$ARG2" ]; then
            set_breathing "$ARG1" "$ARG2"
        elif [ -n "$ARG1" ]; then
            set_breathing "$ARG1"
        else
            set_breathing
        fi
        ;;
    -*)
        echo "Error: Unknown option: $1" >&2
        usage
        ;;
    *)
        echo "Error: Unknown command: $1" >&2
        usage
        ;;
    esac
done
